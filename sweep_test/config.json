{
  "paths": {
    "repo_root": "..",
    "sim_dir": "../L1-08_sim",
    "base_experiment_config": "../L1_08_experiment_config.json",
    "output_root": "../sweep_result"
  },
  "output": {
    "group_by_current_seed": true,
    "overwrite_existing_combo": true,
    "cleanup_sim_outputs_after_copy": false
